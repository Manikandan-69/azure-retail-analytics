{
	"name": "ds_csv_sink",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_adls_retail",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"foldername": {
				"type": "string"
			},
			"filename": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": "@{dataset().filename}",
				"folderPath": "staged/@{dataset().foldername}",
				"fileSystem": "bronze"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	}
}